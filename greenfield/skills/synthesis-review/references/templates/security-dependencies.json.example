  "dependencies": [
    {
      "path": "dataArchitecture.compliance",
      "value": "SOC 2",
      "rationale": "Compliance scope locks sensitivityTier to 'high' and forces sbom=true. Drives Sec.Q1 default, Sec.Q9 (audit retention) required, Sec.Q13 (supply chain) sbom default."
    },
    {
      "path": "apiIntegration.externalServices",
      "value": ["stripe"],
      "rationale": "Payment provider in external services elevates sensitivityTier to 'elevated'. Drives Sec.Q1 default."
    },
    {
      "path": "auth.strategy",
      "value": "hosted",
      "rationale": "Auth strategy determines which secrets enter security.secrets inventory. Hosted providers contribute API keys; built-in contributes session secrets."
    },
    {
      "path": "privacy.piiCategories",
      "value": ["email", "payment"],
      "rationale": "Non-empty PII inventory elevates sensitivityTier and recommends perColumnForPII encryption at rest."
    },
    {
      "path": "architecturalFraming.topology",
      "value": "microservices",
      "rationale": "Microservice topology recommends mTLS for service-to-service encryption in transit."
    },
    {
      "path": "architecturalFraming.scaleTarget",
      "value": "production-scale",
      "rationale": "Scale target gates Sec.Q11 (pentestCadence) and Sec.Q12 (vdp) visibility. Hobby scale auto-skips both."
    }
  ]
}
