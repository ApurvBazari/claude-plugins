{
  "schemaVersion": 1,
  "phase": "privacy",
  "recordedAt": "2026-05-14T16:30:00Z",
  "dependencies": [
    {
      "path": "auth.strategy",
      "value": "hosted",
      "rationale": "Privacy.Gate fires when auth.strategy='none' to confirm whether any user data is collected. 'No' triggers synthesisStatus='n/a' stub — all eight sections are skipped and only the stub banner is rendered. Any value other than 'none' means users exist and Privacy synthesis must run in full."
    },
    {
      "path": "dataArchitecture.compliance",
      "value": "GDPR",
      "rationale": "Pre-fills privacy.regulations on entry. Compliance scope drives lawful-basis requirement (Section 3 gated on GDPR/UK-GDPR), DSAR SLA (Section 5 gated on GDPR/CCPA), and access-audit mandate (Section 8 mandatory on HIPAA). Stale trigger: if dataArchitecture.compliance changes after privacy is approved, privacy synthesisStatus becomes 'stale'."
    },
    {
      "path": "apiIntegration.externalServices",
      "value": ["stripe", "segment"],
      "rationale": "External services that touch user data become candidate Privacy processors (privacy.processors[]). Pre-fills the processor inventory in Section 6. Stale trigger: if new external services are added to apiIntegration after privacy is approved, the processor list may be incomplete — synthesis becomes 'stale'."
    },
    {
      "path": "auth.lifecycle.accountDeletion",
      "value": "hard-delete",
      "rationale": "Privacy deletion flow (privacy.deletionFlow.mechanism) must align with auth account deletion semantics. Contradiction fires if privacy.deletionFlow.mechanism='hard-delete' but auth.lifecycle.accountDeletion is 'soft-delete'. Both layers must agree to avoid residual PII after account removal."
    },
    {
      "path": "architecturalFraming.deploymentShape",
      "value": "cloud-managed",
      "rationale": "Data residency restriction (privacy.dataResidency.restriction) is checked against the deployment shape. Contradiction fires if residency requires EU-only but deploymentShape includes a non-EU region. Drives the Standard Contractual Clause requirement for cross-border transfers."
    }
  ]
}
