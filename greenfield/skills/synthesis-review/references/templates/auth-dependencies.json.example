{
  "schemaVersion": 1,
  "phase": "auth",
  "recordedAt": "2026-05-14T16:30:00Z",
  "dependencies": [
    {
      "path": "dataArchitecture.engine",
      "value": "postgresql",
      "rationale": "Authz model option RLS is only feasible on engines with native row-level security (Postgres, MySQL 8+). Drives Auth.Q5 default + synthesis contradiction in section 5."
    },
    {
      "path": "dataArchitecture.multiTenancy",
      "value": "row-level-rls",
      "rationale": "When the data layer is multi-tenant, Auth must define how tenants are resolved per request (subdomain / path / claim / header). Drives Auth.Q6 visibility."
    },
    {
      "path": "apiIntegration.style",
      "value": "rest",
      "rationale": "API style determines where authorization checks attach — middleware for REST, schema directives for GraphQL, RPC interceptors for tRPC. Drives Auth.Q12 default."
    },
    {
      "path": "architecturalFraming.topology",
      "value": "microservices",
      "rationale": "Service-to-service auth (Auth.Q7) is rendered only for microservices topology. Monoliths skip the s2s section entirely."
    },
    {
      "path": "architecturalFraming.scaleTarget",
      "value": "production-scale",
      "rationale": "Scale target locks MFA required-vs-optional default. Compliance-tier scale targets force MFA required across the board."
    }
  ]
}
