  "dependencies": [
    {
      "path": "apiIntegration.asyncPattern",
      "value": "queue-and-worker",
      "rationale": "asyncPattern=none auto-skips background jobs (Section 1) entirely. Other values determine job system default."
    },
    {
      "path": "auth.serviceAuth",
      "value": "signed-jwt",
      "rationale": "Service-to-service auth determines how health-check endpoints authenticate cross-service probes."
    },
    {
      "path": "security.sensitivityTier",
      "value": "high",
      "rationale": "High sensitivity tier forces alerting.tool ≠ 'none'. Drives Ops.Q7 lock."
    },
    {
      "path": "architecturalFraming.topology",
      "value": "microservices",
      "rationale": "Microservice topology elevates traces (Section 4) from optional to recommended. Drives Ops.Q5 default."
    },
    {
      "path": "architecturalFraming.scaleTarget",
      "value": "production-scale",
      "rationale": "Scale target gates SLO section visibility (hidden for hobby + startup). Drives Ops.Q8 default."
    },
    {
      "path": "architecturalFraming.deploymentShape",
      "value": "kubernetes",
      "rationale": "Deployment shape drives platform-specific defaults for scheduling (k8s CronJob), health checks (liveness/readiness/deep probes), and observability stack."
    }
  ]
