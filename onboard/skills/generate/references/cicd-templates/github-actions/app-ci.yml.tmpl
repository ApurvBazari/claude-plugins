# Application CI pipeline — runs on every PR and push to main.
# Template rendered by onboard:generate (v2 path) consuming context.phases.P8.cicd.
# Placeholders use {{phase.cicd.<field>}} syntax; the generate skill substitutes
# values from the v2 context before injecting the rendered string into the
# config-generator agent's prompt for writing to .github/workflows/ci.yml.
#
# Fields consumed: triggers[], requiredPreMergeChecks[], coverage{}, buildMatrix{},
# caching{}, timeBudget{}, secrets{}, notifications{}.
#
# This is GHA-only; non-GHA providers (gitlab-ci, circleci, etc.) are accepted
# at the wizard level but produce a skip note in onboard 2.0.0-alpha.1 — full
# templates land in Round 6.

name: CI

on:
  # {{triggers}} drives the on: block. push-to-main → push.branches; every-pr →
  # pull_request; scheduled → schedule.cron; manual → workflow_dispatch; tag → push.tags.
  {{#if triggers.includes("push-to-main")}}push:
    branches: [main]
  {{/if}}
  {{#if triggers.includes("every-pr")}}pull_request:
    branches: [main]
  {{/if}}
  {{#if triggers.includes("scheduled")}}schedule:
    - cron: "0 6 * * *"
  {{/if}}
  {{#if triggers.includes("manual")}}workflow_dispatch:
  {{/if}}
  {{#if triggers.includes("tag")}}push:
    tags: ["v*"]
  {{/if}}

permissions:
  contents: read
  pull-requests: read

# {{timeBudget.perPipelineMinutes}} is the soft target; the hard ceiling below
# is timeBudget.blockingThresholdMinutes (or +5 default if null).
env:
  CI_TIME_BUDGET_MINUTES: "{{timeBudget.perPipelineMinutes}}"

jobs:
  checks:
    name: Pre-merge gates
    # {{buildMatrix.os}} → strategy.matrix.os; languageVersions=multi expands the
    # version array; parallelization=off forces max-parallel: 1.
    runs-on: ${{ matrix.os }}
    timeout-minutes: {{timeBudget.blockingThresholdMinutes | default: 30}}
    strategy:
      fail-fast: false
      matrix:
        os: {{buildMatrix.os | as-yaml-array}}
        {{#if buildMatrix.languageVersions == "multi"}}node: [20, 22]{{/if}}
      {{#if buildMatrix.parallelization == "off"}}max-parallel: 1{{/if}}

    steps:
      - uses: actions/checkout@v4

      # {{caching.deps}} enables the install-cache. The actions/setup-* family
      # auto-uses cache: 'npm' / 'pnpm' / etc. depending on the detected pkg manager.
      - name: Setup runtime
        uses: actions/setup-node@v4
        with:
          node-version: {{#if buildMatrix.languageVersions == "multi"}}${{ matrix.node }}{{else}}"22"{{/if}}
          {{#if caching.deps}}cache: "npm"{{/if}}

      - name: Install dependencies
        run: npm ci

      # The requiredPreMergeChecks[] array drives which jobs fire. Each check
      # below is gated by its inclusion in the array. Missing checks emit a skip.
      {{#if requiredPreMergeChecks.includes("lint")}}
      - name: Lint
        run: npm run lint
      {{/if}}

      {{#if requiredPreMergeChecks.includes("typecheck")}}
      - name: Typecheck
        run: npm run typecheck
      {{/if}}

      {{#if requiredPreMergeChecks.includes("unit")}}
      - name: Unit tests
        run: npm run test:unit
      {{/if}}

      {{#if requiredPreMergeChecks.includes("integration")}}
      - name: Integration tests
        run: npm run test:integration
      {{/if}}

      {{#if requiredPreMergeChecks.includes("e2e")}}
      - name: E2E tests
        run: npm run test:e2e
      {{/if}}

      {{#if requiredPreMergeChecks.includes("security-scan")}}
      - name: Security scan
        run: npm audit --audit-level=high
      {{/if}}

      {{#if requiredPreMergeChecks.includes("coverage")}}
      - name: Coverage
        run: npm run test:coverage
        # {{coverage.blocking}} = true causes coverage failures to block the job;
        # = false makes them advisory (continue-on-error: true).
        continue-on-error: {{coverage.blocking == false}}
      {{/if}}

      {{#if requiredPreMergeChecks.includes("build")}}
      - name: Build
        run: npm run build
        # Build artifacts cached if caching.build=true.
        {{#if caching.build}}
      - name: Cache build artifacts
        uses: actions/cache@v4
        with:
          path: dist
          key: build-${{ github.sha }}
        {{/if}}
      {{/if}}

      # {{notifications.channels}} drives downstream notification jobs.
      # GitHub-checks-only is the no-op default; slack/discord/email require
      # secrets configured per {{secrets.manager}}.
      {{#if notifications.channels.includes("slack") && notifications.events.includes("build-failure")}}
      - name: Notify Slack on failure
        if: failure()
        uses: slackapi/slack-github-action@v1
        with:
          payload: |
            {"text": "CI failed on ${{ github.repository }} @ ${{ github.sha }}"}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK
      {{/if}}

