# Deployment pipeline — promotes through envLadder with optional rollback.
# Template rendered by onboard:generate (v2 path). NEW in onboard 2.0 — not
# generated by v1; deploys were managed by app-ci.yml in the v1 world.
#
# Fields consumed: envLadder[], autoDeploy, deployCadence, rollback{},
# secrets.manager, notifications{}, releasePipeline{}.
#
# This file is emitted only when willDeploy = true AND autoDeploy != "none"
# (a wizard-level skip — see generate/SKILL.md § Step 1.5).

name: Deploy

on:
  {{#if autoDeploy == "auto-on-merge"}}
  push:
    branches: [main]
  {{/if}}

  {{#if autoDeploy == "manual-button"}}
  workflow_dispatch:
    inputs:
      environment:
        description: "Target environment"
        type: choice
        options: {{envLadder | as-yaml-array}}
        required: true
  {{/if}}

  {{#if autoDeploy == "scheduled"}}
  schedule:
    {{#if deployCadence == "daily"}}- cron: "0 2 * * *"{{/if}}
    {{#if deployCadence == "weekly"}}- cron: "0 2 * * 1"{{/if}}
  {{/if}}

  {{#if autoDeploy == "tag-triggered"}}
  push:
    tags: ["v*"]
  {{/if}}

permissions:
  contents: read
  # OIDC token write permission when {{secrets.manager == "oidc-to-cloud"}}.
  {{#if secrets.manager == "oidc-to-cloud"}}id-token: write{{/if}}

# Deploys cascade through envLadder. Each environment depends on the previous
# completing successfully. The job names are dynamic — generate substitutes
# one job per env in envLadder[].
jobs:
  {{#each envLadder as env, index}}
  deploy-{{env}}:
    name: Deploy → {{env}}
    runs-on: ubuntu-latest
    timeout-minutes: 30
    environment:
      name: {{env}}
      # Each environment can require approval (configured in repo settings).
    {{#if index > 0}}
    needs: deploy-{{envLadder[index - 1]}}
    {{/if}}

    steps:
      - uses: actions/checkout@v4

      - name: Setup runtime
        uses: actions/setup-node@v4
        with:
          node-version: "22"
          cache: "npm"

      # Secret loading. {{secrets.manager}} drives the secret-fetch step.
      {{#if secrets.manager == "provider-stored"}}
      - name: Use GitHub Actions secrets
        run: echo "Using built-in github.token + repo secrets"
      {{/if}}

      {{#if secrets.manager == "oidc-to-cloud"}}
      - name: Configure cloud credentials via OIDC
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: ${{ secrets.AWS_DEPLOY_ROLE_{{env | upper}} }}
          aws-region: us-east-1
      {{/if}}

      {{#if secrets.manager == "vault"}}
      - name: Fetch secrets from Vault
        uses: hashicorp/vault-action@v3
        with:
          url: ${{ secrets.VAULT_ADDR }}
          method: jwt
          path: github
          role: deploy-{{env}}
      {{/if}}

      {{#if secrets.manager == "doppler"}}
      - name: Load Doppler secrets
        uses: dopplerhq/secrets-fetch-action@v1
        with:
          doppler-token: ${{ secrets.DOPPLER_TOKEN }}
          doppler-environment: {{env}}
      {{/if}}

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build

      - name: Deploy to {{env}}
        id: deploy
        run: npm run deploy:{{env}}

      # Rollback step — only emitted when rollback.strategy != "none" AND
      # rollback.automation = true. Otherwise rollback is operator-driven.
      {{#if rollback.strategy != "none" && rollback.automation == true}}
      - name: Rollback {{env}} on failure
        if: failure() && steps.deploy.outcome == 'failure'
        run: |
          {{#if rollback.strategy == "redeploy-previous-sha"}}
          PREV_SHA=$(git rev-parse HEAD~1)
          git checkout "$PREV_SHA"
          npm ci && npm run build && npm run deploy:{{env}}
          {{/if}}
          {{#if rollback.strategy == "blue-green"}}
          npm run deploy:{{env}}:rollback-blue-green
          {{/if}}
          {{#if rollback.strategy == "canary"}}
          npm run deploy:{{env}}:rollback-canary
          {{/if}}
      {{/if}}

      # Notification routing. deploy-success / deploy-failure events from
      # {{notifications.events}} gate the appropriate Slack/Discord/email steps.
      {{#if notifications.channels.includes("slack") && notifications.events.includes("deploy-success")}}
      - name: Notify Slack on deploy success
        if: success()
        uses: slackapi/slack-github-action@v1
        with:
          payload: |
            {"text": "Deployed to {{env}}: ${{ github.repository }} @ ${{ github.sha }}"}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_DEPLOY_WEBHOOK }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK
      {{/if}}

      {{#if notifications.channels.includes("slack") && notifications.events.includes("deploy-failure")}}
      - name: Notify Slack on deploy failure
        if: failure()
        uses: slackapi/slack-github-action@v1
        with:
          payload: |
            {"text": "DEPLOY FAILED to {{env}}: ${{ github.repository }} @ ${{ github.sha }}"}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_DEPLOY_WEBHOOK }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK
      {{/if}}

  {{/each}}

# References:
#   - envLadder semantics: ../../../../../onboard/skills/generate/references/sprint-contracts-template.json
#   - Secret manager wiring: greenfield/skills/context-gathering/references/question-bank.md § Q5.12
#   - Notification wiring: ./evolution-wiring.md
