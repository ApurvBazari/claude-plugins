# Tooling-audit pipeline — runs onboard's drift detection on a schedule + on
# config-touching PRs. Template rendered by onboard:generate (v2 path).
#
# Fields consumed: triggers[] (for the on: block), notifications{} (for failure
# alerting), secrets.manager (for the actor's OIDC config when applicable).
#
# This pipeline is separate from app-ci so tooling drift doesn't block product
# work. It runs the structural checks in audit-tooling.sh and reports findings
# either as a PR (when {{_v1_carryover.ciAuditAction}} === "create-pr"),
# a commit comment, or a GitHub issue.

name: Tooling Audit

on:
  schedule:
    - cron: "0 8 * * 1"  # Monday 08:00 UTC — weekly drift check
  pull_request:
    paths:
      - "CLAUDE.md"
      - ".claude/**"
      - ".github/**"
      - "package.json"
      - "package-lock.json"
  workflow_dispatch:

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  audit:
    name: Audit Claude tooling
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - uses: actions/checkout@v4

      - name: Setup runtime
        uses: actions/setup-node@v4
        with:
          node-version: "22"
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      # The audit script is shipped by onboard at .claude/scripts/audit-tooling.sh
      # (project-relative — see plugin-script-paths.md § Generated-artifact form).
      - name: Run tooling audit
        id: audit
        run: bash .claude/scripts/audit-tooling.sh
        continue-on-error: true

      # {{_v1_carryover.ciAuditAction}} drives the report path:
      #   "create-pr"  → open a fixup PR with the audit-suggested diffs
      #   "comment"    → comment on the originating commit/PR
      #   "issue"      → open a GitHub issue
      {{#if _v1_carryover.ciAuditAction == "create-pr"}}
      - name: Open fixup PR
        if: steps.audit.outputs.has_findings == 'true'
        uses: peter-evans/create-pull-request@v6
        with:
          title: "chore(tooling): audit findings ${{ github.run_id }}"
          body: "Auto-generated by tooling-audit. Findings in `audit-report.md`."
          branch: tooling-audit/${{ github.run_id }}
          commit-message: "chore(tooling): apply audit suggestions"
      {{/if}}

      {{#if _v1_carryover.ciAuditAction == "comment"}}
      - name: Comment on commit
        if: steps.audit.outputs.has_findings == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const body = fs.readFileSync('audit-report.md', 'utf8');
            await github.rest.repos.createCommitComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              commit_sha: context.sha,
              body
            });
      {{/if}}

      {{#if _v1_carryover.ciAuditAction == "issue"}}
      - name: Open GitHub issue
        if: steps.audit.outputs.has_findings == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const body = fs.readFileSync('audit-report.md', 'utf8');
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `Tooling audit findings — run ${context.runId}`,
              body,
              labels: ['tooling', 'drift']
            });
      {{/if}}

      # Notification routing. {{notifications.events.includes("security-alert")}}
      # specifically gates here because audit findings sometimes flag security.
      {{#if notifications.channels.includes("slack") && notifications.events.includes("security-alert")}}
      - name: Notify Slack on audit findings
        if: steps.audit.outputs.has_findings == 'true'
        uses: slackapi/slack-github-action@v1
        with:
          payload: |
            {"text": "Tooling audit found drift in ${{ github.repository }}"}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK
      {{/if}}

# References:
#   - audit-tooling.sh: ${CLAUDE_PLUGIN_ROOT}/scripts/audit-tooling.sh (in-plugin)
#   - Notification wiring: ./evolution-wiring.md
#   - v1 carryover semantics: ../../../../../onboard/CHANGELOG-2.0.md § Breaking-change matrix
