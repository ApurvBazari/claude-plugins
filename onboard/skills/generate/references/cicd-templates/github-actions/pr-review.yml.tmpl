# PR review pipeline — invokes claude-code-action for AI-driven PR review.
# Template rendered by onboard:generate (v2 path).
#
# Fields consumed: _v1_carryover.prReviewTrigger (Q5.3 from greenfield 2.x),
# notifications{} (for review-completion alerts).
#
# Three trigger modes:
#   "auto-every"           → fires on every PR open + synchronize
#   "comment-mention"      → fires only when a comment contains "@claude"
#   "auto-with-skip-label" → fires on every PR unless 'skip-claude' label present

name: PR Review

on:
  {{#if _v1_carryover.prReviewTrigger == "auto-every"}}
  pull_request:
    types: [opened, synchronize, reopened]
  {{/if}}

  {{#if _v1_carryover.prReviewTrigger == "comment-mention"}}
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  {{/if}}

  {{#if _v1_carryover.prReviewTrigger == "auto-with-skip-label"}}
  pull_request:
    types: [opened, synchronize, reopened, labeled, unlabeled]
  {{/if}}

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  review:
    name: Claude PR review
    runs-on: ubuntu-latest
    timeout-minutes: 15

    # Skip-label gating for auto-with-skip-label mode.
    {{#if _v1_carryover.prReviewTrigger == "auto-with-skip-label"}}
    if: "!contains(github.event.pull_request.labels.*.name, 'skip-claude')"
    {{/if}}

    # Comment-mention gating: only fire on @claude mentions.
    {{#if _v1_carryover.prReviewTrigger == "comment-mention"}}
    if: |
      (github.event_name == 'issue_comment' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review_comment' && contains(github.event.comment.body, '@claude'))
    {{/if}}

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Invoke claude-code-action
        uses: anthropics/claude-code-action@v1
        with:
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          github_token: ${{ secrets.GITHUB_TOKEN }}
          # claude-code-action reads CLAUDE.md and project rules for context.

      {{#if notifications.channels.includes("slack") && notifications.events.includes("build-failure")}}
      - name: Notify Slack on review failure
        if: failure()
        uses: slackapi/slack-github-action@v1
        with:
          payload: |
            {"text": "Claude PR review job failed on ${{ github.repository }} PR #${{ github.event.pull_request.number }}"}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK
      {{/if}}

# References:
#   - claude-code-action: https://github.com/anthropics/claude-code-action
#   - Trigger-mode semantics: greenfield/skills/context-gathering/references/question-bank.md § Q5.3
