{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ApurvBazari/claude-plugins/onboard/schemas/research-dossier.json",
  "title": "Onboard Research — Synthesized Dossier (research object)",
  "description": "The synthesized research object written to .claude/onboard-research.json and carried in the v3 context's `research` field. The markdown artifacts and the optional interactive HTML are renders of this object.",
  "type": "object",
  "required": ["engineUsed", "depth", "roster", "findings", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "engineUsed": { "enum": ["subagent", "workflow"] },
    "depth": { "enum": ["minimal", "standard", "comprehensive"] },
    "roster": {
      "type": "object",
      "required": ["builtins"],
      "additionalProperties": false,
      "properties": {
        "builtins": { "type": "array", "items": { "type": "string" } },
        "disabledBuiltins": { "type": "array", "items": { "type": "string" } },
        "customSpecialists": { "type": "array", "items": { "type": "string" } }
      }
    },
    "findings": {
      "type": "object",
      "description": "Map of dimension -> specialist finding set; each value conforms to research-findings.json."
    },
    "verifiedClaims": { "type": "array", "items": { "type": "string" } },
    "droppedClaims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["location"],
      "additionalProperties": false,
      "properties": {
        "location": { "enum": ["committed", "local", "none"] },
        "written": { "type": "array", "items": { "type": "string" } },
        "html": { "type": ["string", "null"] }
      }
    },
    "wizardInferences": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value"],
        "additionalProperties": false,
        "properties": {
          "value": {},
          "evidence": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
